# Template for .env — copy to `.env` and fill in real values. This file is committed; .env is not.
#
#   cp .env.example .env   &&   edit .env
#
# arxiv-paper-finder's fetcher auto-loads .env (no `source` needed). Without a key,
# Semantic Scholar is skipped and citation counts come from OpenAlex instead.

# Semantic Scholar API key — sent as the `x-api-key` header (never as a query param).
# Get one at https://www.semanticscholar.org/product/api . Rate limit: <1 req/sec.
S2_API_KEY=
